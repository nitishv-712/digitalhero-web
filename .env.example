# Web Frontend Environment Configuration
# =======================================

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:4000

# Supabase Public Configuration (use Anon Key - safe for client-side)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Stripe Public Key (safe for client-side)
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_your_test_key_here

# Application URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Digital Heroes
